# Backend
DATABASE_URL=postgresql+asyncpg://nusaops:password@localhost:5432/nusaops
REDIS_URL=redis://localhost:6379/0

# WhatsApp (Meta)
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=meta_app_secret_for_signature_verification

# AI / LLM
GOOGLE_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_as_fallback
EMBEDDING_MODEL=models/text-embedding-004
LLM_MODEL=gemini-2.0-flash
FALLBACK_LLM_MODEL=gpt-4o-mini

# Auth
JWT_SECRET=your_jwt_secret_key
ADMIN_DEFAULT_PASSWORD=change_me_on_first_login

# Infrastructure
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
